# Config for tool/send_push.dart (universal FCM v1 push tester).
# Copy to tool/.env and fill in. tool/.env is gitignored - do NOT commit it.
#   cp tool/.env.example tool/.env

# Firebase project that owns the app + its APNs config.
# For the local stack this matches FCM_PROJECT_ID__1 (sip_stack/docker-compose.yml).
FCM_PROJECT_ID=webtrit-app

# Path to a Firebase service account JSON with the Cloud Messaging permission.
# Absolute path, or relative to this .env file.
SERVICE_ACCOUNT_JSON=/absolute/path/to/firebase-service-account.json

# FCM registration token of YOUR test device. Read it from the app:
# SessionStatusCubit logs `pushToken: <fcm token>` (the long colon-separated one,
# e.g. fXXXX...:APA91b...). The app must be a build whose bundle id is registered
# in the Firebase project above (e.g. com.webtrit.app).
DEVICE_FCM_TOKEN=

# Notification content (override per run with --title / --body).
PUSH_TITLE=Test push
PUSH_BODY=hello

# Optional: explicit data payload as a JSON object (override per run with --data).
# If empty, a chat-shaped default is built from the CHAT_* keys below.
# Example: PUSH_DATA={"chat_id":"7","chat_type":"direct","chat_message_id":"1","chat_message_sender_id":"2"}
PUSH_DATA=

# Default chat-shaped data (used only when PUSH_DATA / --data is not set).
CHAT_ID=7
CHAT_TYPE=direct
CHAT_MESSAGE_ID=999
CHAT_SENDER_ID=1152127

# ---- Behaviour -------------------------------------------------------------
# App backgrounded or screen locked:
#   silent -> banner appears, NO sound
#   loud   -> banner appears WITH the default chime
# On the foreground the app plays its own sound regardless, so test in background.
#
# Common errors:
#   404 UNREGISTERED            -> stale/wrong device token (re-read it from the app)
#   403 / SENDER_ID_MISMATCH    -> token belongs to a different Firebase project
#   400 third_party_auth_error  -> no APNs key/cert uploaded in Firebase for this
#                                  bundle id (iOS delivery itself will not work)
