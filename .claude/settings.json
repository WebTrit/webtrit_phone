{
  "permissions": {
    "allow": [
      "Bash(flutter test:*)",
      "Bash(flutter analyze:*)",
      "Bash(dart format:*)",
      "Bash(dart fix:*)",
      "Bash(flutter pub get:*)",
      "Bash(flutter gen-l10n:*)",
      "Bash(melos *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git stash:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)"
    ],
    "deny": [
      "Bash(**/.env*)",
      "Read(**/.env*)",
      "Write(**/.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/md_formatter.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Run",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/env_file_guard.py"
          }
        ]
      },
      {
        "matcher": "Read|View|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/env_file_guard.py"
          }
        ]
      }
    ]
  }
}
